# Square Developer Dashboard → your app → Sandbox (or Production) tab
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# Resend (confirmation emails) — resend.com → API Keys
RESEND_API_KEY=
# Optional override; defaults to "The Unraveling <admin@fixatephx.com>"
RESEND_FROM=

# Where registration summaries are sent; defaults to admin@fixatephx.com
REGISTRATION_NOTIFY_EMAIL=

# Google Sheet attendee list (optional — skipped if unset)
# Service account with Sheets access; share the sheet with GOOGLE_SA_EMAIL
GOOGLE_SA_EMAIL=
GOOGLE_SA_KEY=
SHEET_ID=
